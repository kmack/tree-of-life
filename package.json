    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.0.0",
    "prettier": "^3.6.2",
    "three-stdlib": "^2.36.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^3.0.0"
